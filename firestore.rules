
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Use Custom Claims for roles (request.auth.token.role)
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.role == 'admin' || 
              (request.auth.token.email == "ahassanimhoma20@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isEditor() {
      return isAuthenticated() && (isAdmin() || request.auth.token.role == 'editor');
    }
    
    function isJournalist() {
      return isAuthenticated() && (isEditor() || request.auth.token.role == 'journalist');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function fieldUnchanged(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidArticle(data) {
      return hasOnlyAllowedFields(['title', 'content', 'category', 'authorId', 'status', 'mainImage', 'excerpt', 'slug', 'createdAt', 'updatedAt', 'tags', 'views']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 100000 &&
             data.category is string && data.category.size() <= 50 &&
             data.authorId is string && data.authorId.size() == 28 &&
             data.status in ['draft', 'published', 'scheduled'] &&
             (!('mainImage' in data) || (data.mainImage is string && data.mainImage.size() <= 2048)) &&
             (!('excerpt' in data) || (data.excerpt is string && data.excerpt.size() <= 1000)) &&
             (!('slug' in data) || (data.slug is string && data.slug.size() <= 255)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 20));
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'role', 'createdAt', 'photoURL', 'bio']) &&
             data.uid is string && data.uid.size() >= 20 && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 255 &&
             data.role in ['admin', 'editor', 'journalist'] &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 500));
    }

    function isValidSubscriber(data) {
      return hasOnlyAllowedFields(['email', 'subscribedAt', 'status', 'source']) &&
             data.email is string && data.email.size() >= 5 && data.email.size() <= 255 &&
             data.subscribedAt is string &&
             (!('status' in data) || data.status in ['active', 'unsubscribed']);
    }

    function isValidComment(data) {
      return hasOnlyAllowedFields(['articleId', 'userId', 'userName', 'userPhoto', 'content', 'createdAt', 'status']) &&
             data.articleId is string &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 2000 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Articles
    match /articles/{articleId} {
      allow read: if true; 
      
      allow create: if isJournalist() && 
                    isValidArticle(request.resource.data) && 
                    request.resource.data.authorId == request.auth.uid;
      
      allow update: if (isEditor() || (isJournalist() && resource.data.authorId == request.auth.uid)) && 
                    isValidArticle(request.resource.data) && 
                    fieldUnchanged('authorId') && 
                    fieldUnchanged('createdAt');
      
      allow delete: if isEditor();
    }

    // Categories & Authors
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /authors/{authorId} {
      allow read: if true;
      allow write: if isEditor();
    }

    // Users
    match /users/{userId} {
      allow read: if true; 
      
      // Allow creation if:
      // 1. The requester is an admin (to pre-authorize someone)
      // 2. It's the primary admin creating their own first profile
      // 3. The user's email is in the whitelist (self-registration for authorized members)
      allow create: if (isAdmin() || 
                        (request.auth.uid == userId && request.auth.token.email == "ahassanimhoma20@gmail.com") ||
                        (request.auth.uid == userId && exists(/databases/$(database)/documents/whitelist/$(request.auth.token.email.lower())))) && 
                    isValidUser(request.resource.data);
      
      allow update: if (isAdmin() || (request.auth.uid == userId)) && 
                    isValidUser(request.resource.data) &&
                    (isAdmin() || request.resource.data.role == resource.data.role);
      
      allow delete: if isAdmin();
    }

    // Whitelist for authorized members
    match /whitelist/{email} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email.lower() == email.lower());
      allow create, update: if isAdmin();
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.token.email.lower() == email.lower());
    }

    // Subscribers
    match /subscribers/{subscriberId} {
      allow get: if true;
      allow list: if isEditor();
      allow create: if isValidSubscriber(request.resource.data) && 
                    request.resource.data.email == subscriberId; // ID must be the email
      allow update, delete: if isEditor();
    }
    
    // System Config (e.g. for rate limiting or global settings)
    match /system_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Comments
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow update, delete: if isEditor() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
  }
}
