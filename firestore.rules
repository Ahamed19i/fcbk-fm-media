



rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"role": "none"};
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isEditor() {
      return isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor');
    }
    
    function isJournalist() {
      return isAuthenticated() && (isEditor() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'journalist');
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidArticle(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 50000 &&
             data.category is string && data.category.size() <= 50 &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.status in ['draft', 'published', 'scheduled'] &&
             (!('mainImage' in data) || (data.mainImage is string && data.mainImage.size() <= 2048)) &&
             (!('excerpt' in data) || (data.excerpt is string && data.excerpt.size() <= 500)) &&
             (!('slug' in data) || (data.slug is string && data.slug.size() <= 200));
    }

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 255 &&
             data.role in ['admin', 'editor', 'journalist'];
    }

    function isValidSubscriber(data) {
      return data.email is string && data.email.size() >= 5 && data.email.size() <= 255 &&
             data.subscribedAt is string &&
             (!('status' in data) || data.status in ['active', 'unsubscribed']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Articles
    match /articles/{articleId} {
      allow read: if true; 
      allow create: if isJournalist() && isValidArticle(request.resource.data);
      allow update: if isJournalist() && isValidArticle(request.resource.data) && 
                    request.resource.data.authorId == resource.data.authorId; // L'auteur ne change pas
      allow delete: if isEditor();
    }

    // Categories & Authors
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /authors/{authorId} {
      allow read: if true;
      allow write: if isEditor();
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isEditor());
      allow create: if isAdmin(); // Seul un admin peut créer un autre admin/user avec rôle
      allow update: if isAdmin() || (
        request.auth.uid == userId && 
        request.resource.data.role == resource.data.role // Un utilisateur ne peut pas changer son propre rôle
      );
      allow delete: if isAdmin();
    }

    // Subscribers
    match /subscribers/{subscriberId} {
      allow read: if isEditor();
      allow create: if isValidSubscriber(request.resource.data);
      allow update, delete: if isEditor();
    }
  }
}
