{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "A news article published on the platform.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the article" },
        "slug": { "type": "string", "description": "URL slug for the article" },
        "content": { "type": "string", "description": "Rich text content of the article" },
        "excerpt": { "type": "string", "description": "Short summary of the article" },
        "mainImage": { "type": "string", "description": "URL of the main image" },
        "category": { "type": "string", "description": "Category ID" },
        "authorId": { "type": "string", "description": "Author UID" },
        "status": { "type": "string", "enum": ["draft", "published", "scheduled"], "description": "Publication status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" },
        "publishedAt": { "type": "string", "format": "date-time", "description": "Publication timestamp" },
        "views": { "type": "number", "description": "Number of views" },
        "isBreaking": { "type": "boolean", "description": "Whether it's breaking news" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Article tags" }
      },
      "required": ["title", "slug", "content", "category", "authorId", "status", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A category for news articles.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the category" },
        "slug": { "type": "string", "description": "URL slug for the category" },
        "description": { "type": "string", "description": "Description of the category" },
        "order": { "type": "number", "description": "Display order" }
      },
      "required": ["name", "slug"]
    },
    "Author": {
      "title": "Author",
      "description": "A journalist or contributor.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the author" },
        "bio": { "type": "string", "description": "Short biography" },
        "photo": { "type": "string", "description": "URL of the author's photo" },
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "role": { "type": "string", "enum": ["admin", "editor", "journalist"], "description": "User role" }
      },
      "required": ["name", "uid", "role"]
    },
    "User": {
      "title": "User",
      "description": "System user with access to the admin panel.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "enum": ["admin", "editor", "journalist"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation date" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": "Article",
      "description": "Collection of news articles."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of article categories."
    },
    "/authors/{authorId}": {
      "schema": "Author",
      "description": "Collection of authors/journalists."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of system users."
    }
  }
}
